{
  "info": {
    "name": "RentNest API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "rentalRequestId", "value": "" },
    { "key": "paymentIntentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) pm.collectionVariables.set('token', res.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant2@rentnest.com\",\n  \"password\": \"Tenant123!\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) pm.collectionVariables.set('token', res.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rentnest.com\",\n  \"password\": \"ChangeMe123!\"\n}"
            }
          }
        },
        {
          "name": "Login Landlord",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) pm.collectionVariables.set('token', res.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"landlord1@rentnest.com\",\n  \"password\": \"Landlord123!\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "List Properties",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties?page=1&limit=10&city=Dhaka"
          }
        },
        {
          "name": "Get Property",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/:id"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "List My Rentals",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const approved = res.data?.find(r => r.status === 'APPROVED');",
                  "if (approved) pm.collectionVariables.set('rentalRequestId', approved.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/rentals"
          }
        },
        {
          "name": "Submit Rental Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/rentals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"PROPERTY_UUID\",\n  \"moveInDate\": \"2026-08-01\",\n  \"message\": \"I want to rent this property\"\n}"
            }
          }
        },
        {
          "name": "Approve Rental (Landlord)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/landlord/requests/{{rentalRequestId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"APPROVED\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Payments (Stripe)",
      "item": [
        {
          "name": "Create Payment Intent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.paymentIntentId) pm.collectionVariables.set('paymentIntentId', res.data.paymentIntentId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/payments/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"{{rentalRequestId}}\"\n}"
            }
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/payments/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"{{rentalRequestId}}\",\n  \"paymentIntentId\": \"{{paymentIntentId}}\"\n}"
            }
          }
        },
        {
          "name": "Payment History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/payments"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        }
      ]
    }
  ]
}
