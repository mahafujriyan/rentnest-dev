{
  "info": {
    "name": "RentNest API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Tenant\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TENANT\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant1@rentnest.com\",\n  \"password\": \"Tenant123!\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "List Properties",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties?page=1&limit=10&city=Dhaka"
          }
        },
        {
          "name": "Get Property",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/:id"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Submit Rental Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/rentals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"PROPERTY_UUID\",\n  \"moveInDate\": \"2026-08-01\",\n  \"message\": \"I want to rent this property\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        }
      ]
    }
  ]
}
